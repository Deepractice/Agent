{
  "name": "@deepractice-ai/agentx-core",
  "version": "0.1.0",
  "description": "Core implementations for AgentX ecosystem - Session management and agent registry",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "ai",
    "agent",
    "core",
    "session",
    "registry",
    "agentx",
    "deepractice"
  ],
  "author": "Deepractice AI Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Deepractice/Agent.git"
  },
  "bugs": {
    "url": "https://github.com/Deepractice/Agent/issues"
  },
  "homepage": "https://github.com/Deepractice/Agent#readme",
  "dependencies": {
    "@deepractice-ai/agentx-engine": "workspace:*",
    "@deepractice-ai/agentx-event": "workspace:*",
    "@deepractice-ai/agentx-logger": "workspace:*",
    "@deepractice-ai/agentx-types": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.9.2",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
