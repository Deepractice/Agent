{
  "name": "@deepractice-ai/agentx-mealy",
  "version": "0.1.0",
  "description": "Mealy - Functional Mealy Machine framework for AgentX (Source → Processor → Sink)",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "agentx",
    "mealy",
    "mealy-machine",
    "source",
    "processor",
    "sink",
    "store",
    "stateless",
    "functional",
    "automaton",
    "deepractice"
  ],
  "author": "Deepractice AI",
  "license": "MIT",
  "dependencies": {},
  "devDependencies": {
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "vitest": "^1.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
